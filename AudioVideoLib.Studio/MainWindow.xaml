<Window x:Class="AudioVideoLib.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AudioVideoLib.Studio"
        Title="AudioVideoLib Studio"
        Height="800"
        Width="1320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- ==================== styles ==================== -->

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox" x:Key="EditField">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="4,3" />
        </Style>
        <Style TargetType="Border" x:Key="TechCardBorder">
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F9F9F9" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
        <Style TargetType="TextBlock" x:Key="TechCardLabel">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#888888" />
        </Style>
        <Style TargetType="TextBlock" x:Key="TechCardValue">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#222222" />
        </Style>
        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,12,0,12" />
        </Style>

        <!-- ==================== ID3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v2TabViewModel}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Title"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Title,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Artist"       Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Artist,      UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Album,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album Artist" Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding AlbumArtist, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Composer"     Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Composer,    UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Year,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Track, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Disc"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Disc,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Genre" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                        <TextBox   Height="80"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   VerticalScrollBarVisibility="Auto"
                                   local:BubbleScrollBehavior.Enable="True"
                                   Style="{StaticResource EditField}"
                                   Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <GroupBox Grid.Row="1" Margin="0,10,0,0">
                    <GroupBox.Header>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Advanced (all frames)" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="+ Frame"
                                    Margin="12,0,0,0"
                                    Padding="8,1"
                                    FontSize="11"
                                    Click="AddFrameButton_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddFrameMenu" />
                                </Button.ContextMenu>
                            </Button>
                        </DockPanel>
                    </GroupBox.Header>
                    <DataGrid ItemsSource="{Binding AdvancedFrames}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F7F7"
                              MinHeight="150">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Delete frame"
                                                      Click="DeleteFrameMenuItem_Click" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"   Binding="{Binding Identifier}" Width="60"  IsReadOnly="True" />
                            <DataGridTextColumn Header="Type" Binding="{Binding FrameType}"  Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value"
                                                Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="IsReadOnly" Value="{Binding IsReadOnlyInGrid}" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </DataTemplate>

        <!-- ==================== ID3v1 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v1TabViewModel}">
            <Grid Margin="10" Width="520" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Title"   Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Title,   UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <TextBlock Text="Artist"  Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Artist,  UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <TextBlock Text="Album"   Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Album,   UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding Year,  UpdateSourceTrigger=PropertyChanged}" MaxLength="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding TrackNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Genre"  Style="{StaticResource FieldLabel}" />
                    <ComboBox  Margin="0,0,0,6"
                               ItemsSource="{Binding Source={x:Static local:Id3v1TabViewModel.GenreValues}}"
                               IsEditable="True"
                               Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                    <TextBox   MaxLength="28"
                               Style="{StaticResource EditField}"
                               Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ==================== APE editor template ==================== -->

        <DataTemplate DataType="{x:Type local:ApeTabViewModel}">
            <Grid Margin="10">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F7F7F7"
                          MinHeight="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key"   Binding="{Binding Key}"   Width="200" IsReadOnly="True" />
                        <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="90"  IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DataTemplate>

        <!-- ==================== Lyrics3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Lyrics3v2TabViewModel}">
            <Grid Margin="10">
                <DataGrid ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F7F7F7"
                          MinHeight="260">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"    Binding="{Binding Identifier}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DataTemplate>

        <!-- ==================== MusicMatch editor template ==================== -->

        <DataTemplate DataType="{x:Type local:VorbisTabViewModel}">
            <Grid Margin="10">
                <DataGrid ItemsSource="{Binding Entries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F7F7F7"
                          MinHeight="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"  Binding="{Binding Name,  UpdateSourceTrigger=LostFocus}" Width="200" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:MusicMatchTabViewModel}">
            <StackPanel Margin="10" MaxWidth="520" HorizontalAlignment="Left">
                <TextBlock Text="Version"              Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding Version}" />
                <TextBlock Text="Xing Encoder Version" Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding XingEncoderVersion}" />
                <CheckBox  Content="Uses Header"       IsHitTestVisible="False" IsChecked="{Binding UseHeader, Mode=OneWay}" />
                <TextBlock Text="(Read-only in this version)" Foreground="#888888" FontStyle="Italic" Margin="0,10,0,0" />
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- ==================== menu ==================== -->

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Open _Files..."  Click="OpenFiles_Click"  InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Folder..." Click="OpenFolder_Click" InputGestureText="Ctrl+Shift+O" />
                <Separator />
                <MenuItem Header="_Save"           Click="Save_Click"       InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="_Close File"     Click="CloseFile_Click"  InputGestureText="Del" />
                <Separator />
                <MenuItem Header="E_xit"           Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh Current" Click="Refresh_Click" InputGestureText="F5" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- ==================== status bar ==================== -->

        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="StatusLeft" Text="Ready" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusRight" Text="" />
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== main split ==================== -->

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="640" />
            </Grid.ColumnDefinitions>

            <!-- sidebar: file list -->
            <ListBox x:Name="FileList"
                     Grid.Column="0"
                     ItemsSource="{Binding Files}"
                     SelectedItem="{Binding Current, Mode=TwoWay}"
                     HorizontalContentAlignment="Stretch"
                     SelectionChanged="FileList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock TextTrimming="CharacterEllipsis" Foreground="#666666" FontSize="11">
                                    <Run Text="{Binding DisplayTitle}" /><Run Text=" — " /><Run Text="{Binding DisplayArtist}" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding DurationText}" Foreground="#888888" FontSize="10" />
                                    <TextBlock Text="   " />
                                    <TextBlock Text="{Binding BitrateKbps}" Foreground="#888888" FontSize="10" />
                                    <TextBlock Text="k "                     Foreground="#888888" FontSize="10" />
                                    <TextBlock Text="{Binding BitrateMode}"  Foreground="#888888" FontSize="10" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD" />

            <!-- dossier -->

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          x:Name="DossierScroller">
                <StackPanel x:Name="DossierPanel" Margin="16">

                    <!-- header strip: cover + identity -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="160" Height="160"
                                BorderBrush="#CCCCCC" BorderThickness="1" Background="#F5F5F5">
                            <Image Source="{Binding CoverArt}" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HeaderTitle}"  FontSize="24" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding HeaderArtist}" FontSize="14" Foreground="#555555" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding HeaderAlbum}" FontSize="13" Foreground="#666666" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text=" • "                    FontSize="13" Foreground="#999999" />
                                <TextBlock Text="{Binding HeaderYear}"  FontSize="13" Foreground="#666666" />
                            </StackPanel>
                            <Border Margin="0,8,0,0" HorizontalAlignment="Left" Background="#E8EEF7" Padding="6,2" CornerRadius="3">
                                <TextBlock Text="{Binding HeaderSourceBadge, StringFormat='from {0}'}" FontSize="10" Foreground="#3B5998" />
                            </Border>
                            <TextBlock Text="{Binding FilePathDisplay}" FontSize="10" Foreground="#999999" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <!-- technical strip -->
                    <Border Style="{StaticResource SectionBorder}">
                        <StackPanel>
                            <TextBlock Text="TECHNICAL" FontSize="11" FontWeight="SemiBold" Foreground="#999999" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding TechCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TechCardBorder}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource TechCardLabel}" />
                                                <TextBlock Text="{Binding Value}" Style="{StaticResource TechCardValue}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- encoder strip -->
                    <Border Style="{StaticResource SectionBorder}"
                            Visibility="{Binding HasEncoder, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock Text="ENCODER" FontSize="11" FontWeight="SemiBold" Foreground="#999999" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding EncoderSummary}" FontSize="13" FontFamily="Consolas" Foreground="#333333" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- tag format tabs -->
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="0,12,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="TAGS" FontSize="11" FontWeight="SemiBold" Foreground="#999999" VerticalAlignment="Center" />
                                <Button x:Name="AddTagButton"
                                        Content="+ Add tag"
                                        Click="AddTagButton_Click"
                                        HorizontalAlignment="Right"
                                        Padding="10,2"
                                        FontSize="11">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="AddTagMenu" />
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>
                            <TabControl x:Name="TagTabControl"
                                        ItemsSource="{Binding TagTabs}"
                                        MinHeight="320">
                                <TabControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Header}" Margin="4,2" />
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                            </TabControl>
                        </StackPanel>
                    </Border>

                    <!-- hex viewer -->
                    <Expander Header="Hex view" Margin="0,12,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <ComboBox ItemsSource="{Binding HexRegions}"
                                      SelectedItem="{Binding SelectedHexRegion, Mode=TwoWay}"
                                      Margin="0,0,0,6" />
                            <TextBox Text="{Binding HexText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#111111"
                                     Foreground="#DDDDDD"
                                     Height="260"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True" />
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
