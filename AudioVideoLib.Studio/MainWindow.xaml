<Window x:Class="AudioVideoLib.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioVideoLib Studio"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="EditField">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Open _Files..."   Click="OpenFiles_Click"   InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Folder..."  Click="OpenFolder_Click"  InputGestureText="Ctrl+Shift+O" />
                <Separator />
                <MenuItem Header="_Save"            Click="Save_Click"        InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _All"        Click="SaveAll_Click"     InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Remove From List" Click="Remove_Click"     InputGestureText="Del" />
                <Separator />
                <MenuItem Header="E_xit"            Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Select _All"      Click="SelectAll_Click"   InputGestureText="Ctrl+A" />
                <MenuItem Header="_Revert Changes"  Click="Revert_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"           Click="About_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="260" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <!-- Left: tag editor + cover art -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <TextBlock Text="Tag" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />

                    <TextBlock Text="Title"  Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}"
                               Text="{Binding SelectedItem.Title,   ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                    <TextBlock Text="Artist" Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}"
                               Text="{Binding SelectedItem.Artist,  ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                    <TextBlock Text="Album"  Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}"
                               Text="{Binding SelectedItem.Album,   ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}"
                                       Text="{Binding SelectedItem.Year,  ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}"
                                       Text="{Binding SelectedItem.Track, ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Genre"  Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}"
                               Text="{Binding SelectedItem.Genre,   ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                    <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}"
                               Height="60"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               VerticalScrollBarVisibility="Auto"
                               Text="{Binding SelectedItem.Comment, ElementName=FileGrid, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                    <TextBlock Text="Cover" Style="{StaticResource FieldLabel}" Margin="0,8,0,4" />
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="#F7F7F7" MinHeight="140">
                        <Image Source="{Binding SelectedItem.CoverArt, ElementName=FileGrid}"
                               MaxHeight="240"
                               Stretch="Uniform"
                               Margin="4" />
                    </Border>

                    <TextBlock x:Name="TechInfoText"
                               Text="{Binding SelectedItem.TechnicalInfo, ElementName=FileGrid}"
                               Foreground="#888888"
                               FontSize="11"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#DDDDDD"
                          ShowsPreview="True" />

            <!-- Right: file grid -->
            <DataGrid x:Name="FileGrid"
                      Grid.Column="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F5F5F5"
                      RowHeight="22">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="M" Binding="{Binding IsModified}" Width="26" />
                    <DataGridTextColumn Header="Title"    Binding="{Binding Title}"    Width="220" />
                    <DataGridTextColumn Header="Artist"   Binding="{Binding Artist}"   Width="180" />
                    <DataGridTextColumn Header="Album"    Binding="{Binding Album}"    Width="180" />
                    <DataGridTextColumn Header="Year"     Binding="{Binding Year}"     Width="70" />
                    <DataGridTextColumn Header="Track"    Binding="{Binding Track}"    Width="70" />
                    <DataGridTextColumn Header="Genre"    Binding="{Binding Genre}"    Width="110" />
                    <DataGridTextColumn Header="File"     Binding="{Binding FileName}" Width="240" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
