<Window x:Class="AudioVideoLib.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AudioVideoLib.Studio"
        xmlns:analysis="clr-namespace:AudioVideoLib.Studio.Analysis"
        xmlns:playback="clr-namespace:AudioVideoLib.Studio.Playback"
        Title="AudioVideoLib Studio"
        Height="800"
        Width="1320"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox" x:Key="EditField" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- ==================== ID3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v2TabViewModel}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Title"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Title,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Artist"       Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Artist,      UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Album,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album Artist" Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding AlbumArtist, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Composer"     Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Composer,    UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Year,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Track, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Disc"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Disc,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Genre" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                        <TextBox   Height="80"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   VerticalScrollBarVisibility="Auto"
                                   local:BubbleScrollBehavior.Enable="True"
                                   Style="{StaticResource EditField}"
                                   Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <GroupBox Grid.Row="1" Margin="0,10,0,0">
                    <GroupBox.Header>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="All frames" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="+ Frame"
                                    Margin="12,0,0,0"
                                    Padding="8,1"
                                    FontSize="11"
                                    Click="AddFrameButton_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddFrameMenu" />
                                </Button.ContextMenu>
                            </Button>
                        </DockPanel>
                    </GroupBox.Header>
                    <DataGrid ItemsSource="{Binding AdvancedFrames}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource Surface2Brush}"
                              MinHeight="150"
                              MouseDoubleClick="AdvancedGrid_MouseDoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <EventSetter Event="PreviewMouseRightButtonUp" Handler="AdvancedFrameRow_PreviewMouseRightButtonUp" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"   Binding="{Binding Identifier}" Width="60"  IsReadOnly="True" />
                            <DataGridTextColumn Header="Type" Binding="{Binding FrameType}"  Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value"
                                                Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="IsReadOnly" Value="{Binding IsReadOnlyInGrid}" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </DataTemplate>

        <!-- ==================== ID3v1 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v1TabViewModel}">
            <Grid Margin="10" Width="640" HorizontalAlignment="Left">
                <Grid.Resources>
                    <Style x:Key="EncCombo" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                        <Setter Property="Margin" Value="6,0,0,6" />
                        <Setter Property="Width" Value="220" />
                        <Setter Property="ToolTip" Value="Encoding used to decode the bytes — and to re-encode them on save." />
                        <Setter Property="ItemsSource" Value="{Binding Source={x:Static local:Id3v1TabViewModel.EncodingChoices}}" />
                    </Style>
                </Grid.Resources>
                <StackPanel>
                    <TextBlock Text="Title"  Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,0,0,6">
                        <ComboBox DockPanel.Dock="Right" Style="{StaticResource EncCombo}" SelectedItem="{Binding TitleEncoding}" />
                        <TextBox  Style="{StaticResource EditField}" Margin="0" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock Text="Artist" Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,0,0,6">
                        <ComboBox DockPanel.Dock="Right" Style="{StaticResource EncCombo}" SelectedItem="{Binding ArtistEncoding}" />
                        <TextBox  Style="{StaticResource EditField}" Margin="0" Text="{Binding Artist, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock Text="Album"  Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,0,0,6">
                        <ComboBox DockPanel.Dock="Right" Style="{StaticResource EncCombo}" SelectedItem="{Binding AlbumEncoding}" />
                        <TextBox  Style="{StaticResource EditField}" Margin="0" Text="{Binding Album, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" MaxLength="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding TrackNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Genre"  Style="{StaticResource FieldLabel}" />
                    <ComboBox  Margin="0,0,0,6"
                               ItemsSource="{Binding Source={x:Static local:Id3v1TabViewModel.GenreValues}}"
                               IsEditable="True"
                               Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                    <DockPanel Margin="0,0,0,6">
                        <ComboBox DockPanel.Dock="Right" Style="{StaticResource EncCombo}" SelectedItem="{Binding CommentEncoding}" />
                        <TextBox  Style="{StaticResource EditField}" Margin="0" MaxLength="28"
                                  Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ==================== APE editor template ==================== -->

        <DataTemplate DataType="{x:Type local:ApeTabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Item"    Padding="8,2" FontSize="11" Click="AddApeItem_Click"    Tag="{Binding}" />
                    <Button Content="Remove"    Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveApeItem_Click"    Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="280">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <EventSetter Event="PreviewMouseRightButtonUp" Handler="ApeItemRow_PreviewMouseRightButtonUp" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key"   Binding="{Binding Key}"   Width="200" IsReadOnly="True" />
                        <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="90"  IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== Lyrics3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Lyrics3v2TabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Field"  Padding="8,2" FontSize="11" Click="AddLyrics3Field_Click"    Tag="{Binding}" />
                    <Button Content="Remove"   Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveLyrics3Field_Click" Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="240">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <EventSetter Event="PreviewMouseRightButtonUp" Handler="Lyrics3FieldRow_PreviewMouseRightButtonUp" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"    Binding="{Binding Identifier}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== Vorbis editor template ==================== -->

        <DataTemplate DataType="{x:Type local:VorbisTabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Comment" Padding="8,2" FontSize="11" Click="AddVorbisComment_Click"    Tag="{Binding}" />
                    <Button Content="Remove"    Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveVorbisComment_Click" Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Entries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="280">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <EventSetter Event="PreviewMouseRightButtonUp" Handler="VorbisCommentRow_PreviewMouseRightButtonUp" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"  Binding="{Binding Name,  UpdateSourceTrigger=LostFocus}" Width="200" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== MusicMatch editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Lyrics3v1TabViewModel}">
            <DockPanel Margin="10">
                <TextBlock DockPanel.Dock="Top" Text="Lyrics" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                <TextBox Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource EditField}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ContainerTagTabViewModel}">
            <DockPanel Margin="10">
                <TextBlock DockPanel.Dock="Top"
                           Text="(Read-only in this version)"
                           Foreground="#888888"
                           FontStyle="Italic"
                           Margin="0,0,0,6" />
                <DataGrid ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key"   Binding="{Binding Key}"   Width="220" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:MusicMatchTabViewModel}">
            <StackPanel Margin="10" MaxWidth="520" HorizontalAlignment="Left">
                <TextBlock Text="Version"              Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding Version}" />
                <TextBlock Text="Xing Encoder Version" Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding XingEncoderVersion}" />
                <CheckBox  Content="Uses Header"       IsHitTestVisible="False" IsChecked="{Binding UseHeader, Mode=OneWay}" />
                <TextBlock Text="(Read-only in this version)" Foreground="#888888" FontStyle="Italic" Margin="0,10,0,0" />
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- ==================== menu ==================== -->

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..."      Click="OpenFile_Click"  InputGestureText="Ctrl+O" />
                <MenuItem x:Name="RecentMenu" Header="Open _Recent" SubmenuOpened="RecentMenu_SubmenuOpened" />
                <Separator />
                <MenuItem Header="_Save"         Click="Save_Click"      InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..."   Click="SaveAs_Click"    InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem x:Name="ExportJsonMenuItem"
                          Header="_Export tags as JSON..."
                          Click="ExportJson_Click"
                          Visibility="Collapsed" />
                <MenuItem x:Name="ExportLintMenuItem"
                          Header="Export _lint report..."
                          Click="ExportLint_Click"
                          Visibility="Collapsed" />
                <Separator />
                <MenuItem Header="_Batch scan folder..." Click="Batch_Click" />
                <Separator />
                <MenuItem x:Name="CompareMenuItem" Header="Co_mpare with..." Click="Compare_Click" Visibility="Collapsed" />
                <Separator />
                <MenuItem Header="Copy file _path" Click="CopyFilePath_Click" />
                <MenuItem Header="Open in E_xplorer" Click="OpenInExplorer_Click" />
                <Separator />
                <MenuItem Header="_Close file"   Click="CloseFile_Click" InputGestureText="Ctrl+W" />
                <Separator />
                <MenuItem Header="E_xit"         Click="Exit_Click" />
            </MenuItem>
            <MenuItem x:Name="ViewMenu" Header="_View" Visibility="Collapsed">
                <MenuItem Header="_Refresh" Click="Refresh_Click" InputGestureText="F5" />
                <Separator />
                <MenuItem Header="_Go to offset..." Click="GoToOffset_Click" InputGestureText="Ctrl+G" />
                <MenuItem Header="_Find..."         Click="Find_Click"        InputGestureText="Ctrl+F" />
                <MenuItem Header="Find _next"       Click="FindNext_Click"    InputGestureText="F3" />
                <MenuItem Header="Find _previous"   Click="FindPrevious_Click" InputGestureText="Shift+F3" />
                <Separator />
                <MenuItem Header="_Validate all..." Click="ValidateAll_Click" />
                <MenuItem x:Name="FlacIntegrityMenuItem"
                          Header="_FLAC integrity check..."
                          Click="FlacIntegrity_Click"
                          Visibility="Collapsed" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings..." Click="Settings_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Keyboard shortcuts..." Click="Shortcuts_Click" InputGestureText="F1" />
                <Separator />
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- ==================== file tabs ==================== -->

        <Border x:Name="FileTabsStrip"
                DockPanel.Dock="Top"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="FileTabsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2,0" Padding="0" CornerRadius="3"
                                    Background="{Binding TabBackground}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Content="×"
                                            Width="20" Height="20"
                                            Padding="0"
                                            Margin="2,0,2,0"
                                            FontSize="12"
                                            Click="CloseTab_Click"
                                            Tag="{Binding Dossier}"
                                            ToolTip="Close" />
                                    <Button Click="SelectTab_Click"
                                            Tag="{Binding Dossier}"
                                            Padding="8,3"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Content="{Binding DisplayName}"
                                            ToolTip="{Binding FilePath}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ==================== file info strip ==================== -->

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,6">
            <TextBox x:Name="FilePathText"
                     Text="No file loaded. Use File > Open (Ctrl+O)."
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     IsReadOnly="True"
                     IsReadOnlyCaretVisible="False"
                     HorizontalScrollBarVisibility="Hidden"
                     VerticalScrollBarVisibility="Disabled"
                     TextWrapping="NoWrap" />
        </Border>

        <!-- ==================== playback bar ==================== -->

        <playback:PlaybackBar x:Name="PlayBar" DockPanel.Dock="Bottom" Visibility="Collapsed" />

        <!-- ==================== status bar ==================== -->

        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="StatusLeft" Text="Ready" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusSelection"
                           FontFamily="Consolas"
                           FontSize="12"
                           Text="" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusRight" Text="" />
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== main tabs ==================== -->

        <TabControl x:Name="MainTabs">

            <!-- ==================== Inspector tab ==================== -->

            <TabItem Header="Inspector">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="200" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="250" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <!-- top: tree + properties -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" MinWidth="200" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" MinWidth="300" />
                        </Grid.ColumnDefinitions>

                        <!-- tree -->
                        <GroupBox Grid.Column="0" Header="Structure" Margin="4">
                            <TreeView x:Name="InspectorTreeView"
                                      BorderThickness="0"
                                      FontFamily="Consolas"
                                      FontSize="12"
                                      SelectedItemChanged="InspectorTreeView_SelectedItemChanged"
                                      ContextMenuOpening="InspectorTree_ContextMenuOpening">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" ToolTip="{Binding OffsetTooltip}">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SizeLabel}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="Normal"
                                                       FontSize="10"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </GroupBox>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD" />

                        <!-- properties -->
                        <GroupBox Grid.Column="2" Header="Properties" Margin="4">
                            <DataGrid x:Name="PropertiesGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="False"
                                      CanUserReorderColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      RowHeight="24"
                                      SelectionChanged="PropertiesGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="140" CanUserSort="False">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Setter Property="Padding" Value="4,3" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" CanUserSort="False">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas" />
                                                <Setter Property="FontSize" Value="12" />
                                                <Setter Property="Padding" Value="4,3" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#DDDDDD" />

                    <!-- hex view -->
                    <GroupBox Grid.Row="2" Header="Hex View" Margin="4">
                        <local:HexView x:Name="HexViewControl" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ==================== Analysis tab ==================== -->

            <TabItem Header="Analysis">
                <analysis:AnalysisPanel x:Name="AnalysisPanel" />
            </TabItem>

            <!-- ==================== Tags tab ==================== -->

            <TabItem Header="Tags">
                <DockPanel>
                    <!-- unsaved changes banner -->
                    <Border x:Name="UnsavedBanner"
                            DockPanel.Dock="Top"
                            Background="#FF3C3C14"
                            BorderBrush="#FF8C8C00"
                            BorderThickness="0,0,0,1"
                            Padding="10,6"
                            Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Save As..." Click="SaveAs_Click" Padding="10,2" FontSize="11" Margin="8,0,0,0" />
                            <Button DockPanel.Dock="Right" Content="Save" Click="Save_Click" Padding="10,2" FontSize="11" />
                            <TextBlock Text="You have unsaved changes. Use Save to overwrite or Save As to create a copy."
                                       Foreground="#FFCCAA00"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Padding="6,4"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button x:Name="AddTagButton"
                                    DockPanel.Dock="Right"
                                    Content="+ Add tag format"
                                    Click="AddTagButton_Click"
                                    Padding="10,2"
                                    FontSize="11">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddTagMenu" />
                                </Button.ContextMenu>
                            </Button>
                            <Button DockPanel.Dock="Right"
                                    Content="Validate"
                                    Click="ValidateTag_Click"
                                    Padding="10,2"
                                    FontSize="11"
                                    Margin="0,0,8,0" />
                            <TextBlock Text="Select a tag format to edit, or add a new one."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <TabControl x:Name="TagTabControl"
                                Margin="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}" Margin="4,2" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                            <EventSetter Event="PreviewMouseRightButtonUp" Handler="TabItem_PreviewMouseRightButtonUp" />
                        </Style>
                    </TabControl.ItemContainerStyle>
                </TabControl>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
