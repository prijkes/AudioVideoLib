<Window x:Class="AudioVideoLib.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AudioVideoLib.Studio"
        Title="AudioVideoLib Studio"
        Height="800"
        Width="1320"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox" x:Key="EditField" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- ==================== ID3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v2TabViewModel}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Title"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Title,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Artist"       Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Artist,      UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album"        Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Album,       UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Album Artist" Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding AlbumArtist, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Composer"     Style="{StaticResource FieldLabel}" />
                        <TextBox   Style="{StaticResource EditField}" Text="{Binding Composer,    UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Year,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Track, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Disc"  Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Disc,  UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Genre" Style="{StaticResource FieldLabel}" />
                                <TextBox   Style="{StaticResource EditField}" Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                        <TextBox   Height="80"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   VerticalScrollBarVisibility="Auto"
                                   local:BubbleScrollBehavior.Enable="True"
                                   Style="{StaticResource EditField}"
                                   Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <GroupBox Grid.Row="1" Margin="0,10,0,0">
                    <GroupBox.Header>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="All frames" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right"
                                    Content="+ Frame"
                                    Margin="12,0,0,0"
                                    Padding="8,1"
                                    FontSize="11"
                                    Click="AddFrameButton_Click">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddFrameMenu" />
                                </Button.ContextMenu>
                            </Button>
                        </DockPanel>
                    </GroupBox.Header>
                    <DataGrid ItemsSource="{Binding AdvancedFrames}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="{DynamicResource Surface2Brush}"
                              MinHeight="150"
                              MouseDoubleClick="AdvancedGrid_MouseDoubleClick">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <EventSetter Event="PreviewMouseRightButtonUp" Handler="AdvancedFrameRow_PreviewMouseRightButtonUp" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"   Binding="{Binding Identifier}" Width="60"  IsReadOnly="True" />
                            <DataGridTextColumn Header="Type" Binding="{Binding FrameType}"  Width="130" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value"
                                                Binding="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="IsReadOnly" Value="{Binding IsReadOnlyInGrid}" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </DataTemplate>

        <!-- ==================== ID3v1 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Id3v1TabViewModel}">
            <Grid Margin="10" Width="520" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Title"   Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Title,   UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <TextBlock Text="Artist"  Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Artist,  UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <TextBlock Text="Album"   Style="{StaticResource FieldLabel}" />
                    <TextBox   Style="{StaticResource EditField}" Text="{Binding Album,   UpdateSourceTrigger=PropertyChanged}" MaxLength="30" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Year"  Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding Year,  UpdateSourceTrigger=PropertyChanged}" MaxLength="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Track" Style="{StaticResource FieldLabel}" />
                            <TextBox   Style="{StaticResource EditField}" Text="{Binding TrackNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Genre"  Style="{StaticResource FieldLabel}" />
                    <ComboBox  Margin="0,0,0,6"
                               ItemsSource="{Binding Source={x:Static local:Id3v1TabViewModel.GenreValues}}"
                               IsEditable="True"
                               Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Comment" Style="{StaticResource FieldLabel}" />
                    <TextBox   MaxLength="28"
                               Style="{StaticResource EditField}"
                               Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ==================== APE editor template ==================== -->

        <DataTemplate DataType="{x:Type local:ApeTabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Item"    Padding="8,2" FontSize="11" Click="AddApeItem_Click"    Tag="{Binding}" />
                    <Button Content="Remove"    Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveApeItem_Click"    Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="280">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key"   Binding="{Binding Key}"   Width="200" IsReadOnly="True" />
                        <DataGridTextColumn Header="Type"  Binding="{Binding Type}"  Width="90"  IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== Lyrics3v2 editor template ==================== -->

        <DataTemplate DataType="{x:Type local:Lyrics3v2TabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Field"  Padding="8,2" FontSize="11" Click="AddLyrics3Field_Click"    Tag="{Binding}" />
                    <Button Content="Remove"   Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveLyrics3Field_Click" Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="240">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"    Binding="{Binding Identifier}" Width="80" IsReadOnly="True" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== Vorbis editor template ==================== -->

        <DataTemplate DataType="{x:Type local:VorbisTabViewModel}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+ Comment" Padding="8,2" FontSize="11" Click="AddVorbisComment_Click"    Tag="{Binding}" />
                    <Button Content="Remove"    Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="RemoveVorbisComment_Click" Tag="{Binding}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Entries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="{DynamicResource Surface2Brush}"
                          SelectionMode="Single"
                          MinHeight="280">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"  Binding="{Binding Name,  UpdateSourceTrigger=LostFocus}" Width="200" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=LostFocus}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>

        <!-- ==================== MusicMatch editor template ==================== -->

        <DataTemplate DataType="{x:Type local:MusicMatchTabViewModel}">
            <StackPanel Margin="10" MaxWidth="520" HorizontalAlignment="Left">
                <TextBlock Text="Version"              Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding Version}" />
                <TextBlock Text="Xing Encoder Version" Style="{StaticResource FieldLabel}" />
                <TextBox   Style="{StaticResource EditField}" IsReadOnly="True" Text="{Binding XingEncoderVersion}" />
                <CheckBox  Content="Uses Header"       IsHitTestVisible="False" IsChecked="{Binding UseHeader, Mode=OneWay}" />
                <TextBlock Text="(Read-only in this version)" Foreground="#888888" FontStyle="Italic" Margin="0,10,0,0" />
            </StackPanel>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- ==================== menu ==================== -->

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..."      Click="OpenFile_Click"  InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save"         Click="Save_Click"      InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..."   Click="SaveAs_Click"    InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Close file"   Click="CloseFile_Click" InputGestureText="Ctrl+W" />
                <Separator />
                <MenuItem Header="E_xit"         Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh" Click="Refresh_Click" InputGestureText="F5" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- ==================== file info strip ==================== -->

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,6">
            <TextBlock x:Name="FilePathText"
                       Text="No file loaded. Use File > Open (Ctrl+O)."
                       FontFamily="Consolas"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- ==================== status bar ==================== -->

        <StatusBar DockPanel.Dock="Bottom" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="StatusLeft" Text="Ready" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="StatusRight" Text="" />
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== main tabs ==================== -->

        <TabControl x:Name="MainTabs">

            <!-- ==================== Inspector tab ==================== -->

            <TabItem Header="Inspector">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="200" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="250" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <!-- top: tree + properties -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" MinWidth="200" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="*" MinWidth="300" />
                        </Grid.ColumnDefinitions>

                        <!-- tree -->
                        <GroupBox Grid.Column="0" Header="Structure" Margin="4">
                            <TreeView x:Name="InspectorTreeView"
                                      BorderThickness="0"
                                      FontFamily="Consolas"
                                      FontSize="12"
                                      SelectedItemChanged="InspectorTreeView_SelectedItemChanged">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" ToolTip="{Binding OffsetTooltip}">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SizeLabel}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontWeight="Normal"
                                                       FontSize="10"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </GroupBox>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD" />

                        <!-- properties -->
                        <GroupBox Grid.Column="2" Header="Properties" Margin="4">
                            <DataGrid x:Name="PropertiesGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      RowHeight="24"
                                      SelectionChanged="PropertiesGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="140">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Setter Property="Padding" Value="4,3" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas" />
                                                <Setter Property="FontSize" Value="12" />
                                                <Setter Property="Padding" Value="4,3" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#DDDDDD" />

                    <!-- hex view -->
                    <GroupBox Grid.Row="2" Header="Hex View" Margin="4">
                        <RichTextBox x:Name="HexViewBox"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="#1A1A1A" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ==================== Tags tab ==================== -->

            <TabItem Header="Tags">
                <DockPanel>
                    <!-- unsaved changes banner -->
                    <Border x:Name="UnsavedBanner"
                            DockPanel.Dock="Top"
                            Background="#FF3C3C14"
                            BorderBrush="#FF8C8C00"
                            BorderThickness="0,0,0,1"
                            Padding="10,6"
                            Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Save As..." Click="SaveAs_Click" Padding="10,2" FontSize="11" Margin="8,0,0,0" />
                            <Button DockPanel.Dock="Right" Content="Save" Click="Save_Click" Padding="10,2" FontSize="11" />
                            <TextBlock Text="You have unsaved changes. Use Save to overwrite or Save As to create a copy."
                                       Foreground="#FFCCAA00"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Padding="6,4"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button x:Name="AddTagButton"
                                    DockPanel.Dock="Right"
                                    Content="+ Add tag format"
                                    Click="AddTagButton_Click"
                                    Padding="10,2"
                                    FontSize="11">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="AddTagMenu" />
                                </Button.ContextMenu>
                            </Button>
                            <TextBlock Text="Select a tag format to edit, or add a new one."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <TabControl x:Name="TagTabControl"
                                Margin="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}" Margin="4,2" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                            <EventSetter Event="PreviewMouseRightButtonUp" Handler="TabItem_PreviewMouseRightButtonUp" />
                        </Style>
                    </TabControl.ItemContainerStyle>
                </TabControl>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
