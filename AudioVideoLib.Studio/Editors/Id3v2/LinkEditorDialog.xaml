<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.LinkEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Linked information (LINK)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Frame identifier (3 chars on v2.2, 4 chars on v2.3+)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding FrameIdentifier, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="4" Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="URL"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Additional ID data"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding AdditionalIdData, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
        </StackPanel>
    </DockPanel>
</Window>
