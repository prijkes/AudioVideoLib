<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.BinaryDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Binary frame"
        Width="600"
        Height="540"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="OwnerPanel" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="OwnerLabel" Foreground="#666666" FontSize="11" Margin="0,0,0,2" Text="Owner identifier" />
            <TextBox x:Name="OwnerBox" Padding="4,3" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Binary data (hex)" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
        <TextBox Grid.Row="2"
                 x:Name="HexBox"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="11"
                 Background="#111111"
                 Foreground="#DDDDDD"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
            <Button Content="Clear data"      Padding="10,3" Margin="8,0,0,0" Click="ClearData_Click" />
            <TextBlock x:Name="InfoText"      Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#888888" FontSize="11" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="OkButton_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
