<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.GeobEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AudioVideoLib.Studio.Controls"
        Width="520" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="General encapsulated object (GEOB)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Encoding" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding Source={StaticResource Id3v2EncodingValues}}"
                      SelectedValue="{Binding Encoding}" Margin="0,0,0,8" />
            <TextBlock Text="MIME type (e.g. application/octet-stream)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding MimeType, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Filename"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Filename, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Content description"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding ContentDescription, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Encapsulated object — hex / ASCII, both editable"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <ctrl:HexEditor x:Name="HexEditor" Data="{Binding Data}" Height="240" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
                <Button Content="Clear data"      Padding="10,3" Margin="8,0,0,0" Click="ClearData_Click" />
                <TextBlock Text="{Binding DataInfo}" Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
