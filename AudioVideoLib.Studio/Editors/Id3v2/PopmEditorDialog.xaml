<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.PopmEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Popularimeter (POPM)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Email to user"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding EmailToUser, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Rating (0–255)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Rating, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Counter"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Counter, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
        </StackPanel>
    </DockPanel>
</Window>
