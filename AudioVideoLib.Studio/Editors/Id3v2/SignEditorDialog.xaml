<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.SignEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Signature (SIGN)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Group symbol (128–240)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding GroupSymbol, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Signature data"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
                <Button Content="Clear data"      Padding="10,3" Margin="8,0,0,0" Click="ClearData_Click" />
                <TextBlock Text="{Binding DataInfo}" Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
