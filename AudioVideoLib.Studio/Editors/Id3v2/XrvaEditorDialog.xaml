<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.XrvaEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="720" Height="500" WindowStartupLocation="CenterOwner"
        Title="Experimental volume adjustment 2 (XRVA)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="80" Click="Ok_Click" IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Identification (uniqueness key)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Identification, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Add"    Width="70"                  Click="Add_Click" />
            <Button Content="Remove" Width="70" Margin="6,0,0,0" Click="Remove_Click" />
            <Button Content="Up"     Width="50" Margin="6,0,0,0" Click="Up_Click" />
            <Button Content="Down"   Width="50" Margin="6,0,0,0" Click="Down_Click" />
        </StackPanel>
        <DataGrid x:Name="Grid" ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridComboBoxColumn Header="Channel"
                                        ItemsSource="{Binding Source={StaticResource Id3v2ChannelTypeValues}}"
                                        SelectedItemBinding="{Binding ChannelType}"
                                        Width="*" />
                <DataGridTextColumn Header="Volume (dB)"           Binding="{Binding VolumeAdjustment}"     Width="100" />
                <DataGridTextColumn Header="Bits representing peak" Binding="{Binding BitsRepresentingPeak}" Width="140" />
                <DataGridTextColumn Header="Peak volume"           Binding="{Binding PeakVolume}"            Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
