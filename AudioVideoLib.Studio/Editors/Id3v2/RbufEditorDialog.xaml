<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.RbufEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Recommended buffer size (RBUF)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Buffer size (bytes)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding BufferSize, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <CheckBox Content="Embedded info" IsChecked="{Binding UseEmbeddedInfo}" Margin="0,0,0,8" />
            <TextBlock Text="Offset to next tag"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding OffsetToNextTag, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
        </StackPanel>
    </DockPanel>
</Window>
