<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.PossEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Position synchronization (POSS)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Time-stamp format"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding Source={StaticResource Id3v2TimeStampFormatValues}}"
                      SelectedValue="{Binding TimeStampFormat}" Margin="0,0,0,8" />
            <TextBlock Text="Position"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
        </StackPanel>
    </DockPanel>
</Window>
