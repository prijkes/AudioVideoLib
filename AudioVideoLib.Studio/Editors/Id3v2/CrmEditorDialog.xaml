<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.CrmEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="540" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Encrypted meta (CRM)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <StackPanel>
            <TextBlock Text="Owner identifier (RFC 1738 URL)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding OwnerIdentifier, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Content explanation"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <TextBox Text="{Binding ContentExplanation, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3" Margin="0,0,0,8" />
            <TextBlock Text="Frame to wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <ComboBox ItemsSource="{Binding WrappableSnapshot}"
                      SelectedItem="{Binding SelectedChild}"
                      DisplayMemberPath="Identifier"
                      Margin="0,0,0,8" />
            <TextBlock Text="Encrypted data block (override)"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
                <Button Content="Clear data"      Padding="10,3" Margin="8,0,0,0" Click="ClearData_Click" />
                <TextBlock Text="{Binding DataInfo}" Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
