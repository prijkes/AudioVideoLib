<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.ApicEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Picture frame (APIC)"
        Width="560"
        Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="#CCCCCC" BorderThickness="1" Background="#F5F5F5">
            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="6" />
        </Border>

        <StackPanel Grid.Row="0" Grid.Column="2">
            <TextBlock Text="Picture type" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <ComboBox x:Name="PictureTypeCombo" Margin="0,0,0,10" />

            <TextBlock Text="MIME / format" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox x:Name="MimeBox" Padding="4,3" Margin="0,0,0,10" />

            <TextBlock Text="Description" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox x:Name="DescriptionBox" Padding="4,3" Margin="0,0,0,10" />

            <TextBlock x:Name="InfoText" Foreground="#888888" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
            <Button Content="Export to file…" Padding="10,3" Margin="8,0,0,0" Click="ExportToFile_Click" />
            <Button Content="Clear image"     Padding="10,3" Margin="8,0,0,0" Click="ClearImage_Click" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="OkButton_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
