<Window x:Class="AudioVideoLib.Studio.Editors.Id3v2.RvadEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        Title="Relative volume adjustment (RVAD)">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="Ok_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Increment/decrement (bit flags, 0-255)"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBox Text="{Binding IncrementDecrement, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Volume description bits (1-64)"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBox Text="{Binding VolumeDescriptionBits, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="4,3" />
                    </StackPanel>
                </Grid>

                <GroupBox Header="Right / Left (front)" Margin="0,0,0,8" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Right adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Right peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Left adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Left peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeRightChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding PeakVolumeRightChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="2" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeLeftChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="3" Margin="3,0,0,0" Padding="4,3"
                                 Text="{Binding PeakVolumeLeftChannel, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Right / Left (back)" Margin="0,0,0,8" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Right-back adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Right-back peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Left-back adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Left-back peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeRightBackChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding PeakVolumeRightBackChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="2" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeLeftBackChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="3" Margin="3,0,0,0" Padding="4,3"
                                 Text="{Binding PeakVolumeLeftBackChannel, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Center / Bass" Padding="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Center adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Center peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Bass adj"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Bass peak"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeCenterChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding PeakVolumeCenterChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="2" Margin="3,0,3,0" Padding="4,3"
                                 Text="{Binding RelativeVolumeChangeBassChannel, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="1" Grid.Column="3" Margin="3,0,0,0" Padding="4,3"
                                 Text="{Binding PeakVolumeBassChannel, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
