<Window x:Class="AudioVideoLib.Studio.AddApeItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:AudioVideoLib.Studio.Controls"
        Title="Add APE item"
        Width="520"
        Height="520"
        MinWidth="420"
        MinHeight="360"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Type" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <ComboBox x:Name="TypeCombo" Padding="4,3" SelectionChanged="TypeCombo_SelectionChanged">
                <ComboBoxItem Content="Text (UTF-8)" Tag="Text" IsSelected="True" />
                <ComboBoxItem Content="Binary"        Tag="Binary" />
                <ComboBoxItem Content="External locator (URI)" Tag="Locator" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Key (e.g., Title, Artist, Album, Cover Art (Front))"
                       Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox x:Name="KeyBox" Padding="4,3" />
        </StackPanel>

        <Grid Grid.Row="2">
            <!-- Text panel -->
            <StackPanel x:Name="TextPanel">
                <TextBlock Text="Value (UTF-8 string)"
                           Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
                <TextBox x:Name="TextValueBox" Padding="4,3"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="80" />
                <TextBlock Text="Tip: leave empty to add an empty item; use the value column afterward to edit."
                           Foreground="#888888" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Binary panel -->
            <Grid x:Name="BinaryPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Binary data (hex / ASCII — both editable)"
                           Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
                <ctrl:HexEditor Grid.Row="1" x:Name="HexEditor" />
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Load from file…" Padding="10,3" Click="LoadFromFile_Click" />
                    <Button Content="Clear data"      Padding="10,3" Margin="8,0,0,0" Click="ClearData_Click" />
                    <TextBlock x:Name="BinaryInfoText" Margin="14,0,0,0" VerticalAlignment="Center"
                               Foreground="#888888" FontSize="11" />
                </StackPanel>
            </Grid>

            <!-- Locator panel -->
            <StackPanel x:Name="LocatorPanel" Visibility="Collapsed">
                <TextBlock Text="URI (RFC 2396 / RFC 2732)"
                           Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
                <TextBox x:Name="LocatorBox" Padding="4,3" />
                <TextBlock Text="Example: https://example.com/cover.jpg"
                           Foreground="#888888" FontSize="11" Margin="0,6,0,0" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="OkButton_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
