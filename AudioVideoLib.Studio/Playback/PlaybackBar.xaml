<UserControl x:Class="AudioVideoLib.Studio.Playback.PlaybackBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,4">
        <DockPanel>
            <Button x:Name="PlayPauseButton"
                    DockPanel.Dock="Left"
                    Content="▶"
                    Width="32"
                    Margin="0,0,4,0"
                    Click="PlayPause_Click" />
            <Button x:Name="StopButton"
                    DockPanel.Dock="Left"
                    Content="■"
                    Width="28"
                    Margin="0,0,8,0"
                    Click="Stop_Click" />
            <TextBlock x:Name="TimeText"
                       DockPanel.Dock="Left"
                       Text="00:00 / 00:00"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ToggleButton x:Name="VolumeButton"
                          DockPanel.Dock="Right"
                          Content="🔊"
                          Width="28"
                          Height="22"
                          Margin="8,0,0,0"
                          ToolTip="Volume"
                          Cursor="Hand"
                          FontFamily="Segoe UI Emoji"
                          FontSize="14"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                <!-- Custom template so the icon stays visible across idle / hover / pressed / checked.
                     The default ToggleButton chrome wipes the content on hover under the dark theme. -->
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface3Brush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface3Brush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>
            <Popup x:Name="VolumePopup"
                   PlacementTarget="{Binding ElementName=VolumeButton}"
                   Placement="Top"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   IsOpen="{Binding IsChecked, ElementName=VolumeButton, Mode=TwoWay}">
                <Border Background="{DynamicResource Surface2Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="6,8"
                        Margin="0,0,0,4">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock x:Name="VolumeText"
                                   Text="50%"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <Slider x:Name="VolumeSlider"
                                Orientation="Vertical"
                                Minimum="0"
                                Maximum="100"
                                Value="50"
                                Height="120"
                                IsMoveToPointEnabled="True"
                                ValueChanged="VolumeSlider_ValueChanged" />
                    </StackPanel>
                </Border>
            </Popup>
            <TextBlock x:Name="FrameText"
                       DockPanel.Dock="Right"
                       Text=""
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="8,0,0,0"
                       TextAlignment="Right"
                       Visibility="Collapsed" />
            <Slider x:Name="PositionSlider"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    IsMoveToPointEnabled="True"
                    Thumb.DragStarted="PositionSlider_DragStarted"
                    Thumb.DragCompleted="PositionSlider_DragCompleted"
                    PreviewMouseUp="PositionSlider_PreviewMouseUp"
                    VerticalAlignment="Center" />
        </DockPanel>
    </Border>
</UserControl>
