<UserControl x:Class="AudioVideoLib.Studio.Playback.PlaybackBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource Surface2Brush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="8,4">
        <DockPanel>
            <Button x:Name="PlayPauseButton"
                    DockPanel.Dock="Left"
                    Content="▶"
                    Width="32"
                    Margin="0,0,4,0"
                    Click="PlayPause_Click" />
            <Button x:Name="StopButton"
                    DockPanel.Dock="Left"
                    Content="■"
                    Width="28"
                    Margin="0,0,8,0"
                    Click="Stop_Click" />
            <TextBlock x:Name="PositionText"
                       DockPanel.Dock="Left"
                       Text="00:00"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Width="50" />
            <TextBlock x:Name="DurationText"
                       DockPanel.Dock="Right"
                       Text="00:00"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Width="50"
                       Margin="8,0,0,0"
                       TextAlignment="Right" />
            <TextBlock x:Name="FrameText"
                       DockPanel.Dock="Right"
                       Text=""
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="8,0,0,0"
                       TextAlignment="Right"
                       Visibility="Collapsed" />
            <Slider x:Name="PositionSlider"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    IsMoveToPointEnabled="True"
                    Thumb.DragStarted="PositionSlider_DragStarted"
                    Thumb.DragCompleted="PositionSlider_DragCompleted"
                    PreviewMouseUp="PositionSlider_PreviewMouseUp"
                    VerticalAlignment="Center" />
        </DockPanel>
    </Border>
</UserControl>
