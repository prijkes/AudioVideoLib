<Window x:Class="AudioVideoLib.Studio.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="440"
        Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Restore defaults" Padding="12,4" Margin="0,0,8,0" Click="Reset_Click" />
            <Button Content="Cancel" Padding="16,4" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Save" Padding="16,4" IsDefault="True" Click="Save_Click" />
        </StackPanel>
        <StackPanel>
            <GroupBox Header="Hex view" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Bytes per row" Width="160" VerticalAlignment="Center" />
                        <ComboBox x:Name="BytesPerRowBox" Width="80" HorizontalAlignment="Left">
                            <ComboBoxItem Content="8" />
                            <ComboBoxItem Content="16" />
                            <ComboBoxItem Content="24" />
                            <ComboBoxItem Content="32" />
                            <ComboBoxItem Content="48" />
                            <ComboBoxItem Content="64" />
                        </ComboBox>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="Font size (pt)" Width="160" VerticalAlignment="Center" />
                        <ComboBox x:Name="FontSizeBox" Width="80" HorizontalAlignment="Left">
                            <ComboBoxItem Content="9" />
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="11" />
                            <ComboBoxItem Content="12" />
                            <ComboBoxItem Content="14" />
                            <ComboBoxItem Content="16" />
                            <ComboBoxItem Content="18" />
                        </ComboBox>
                    </DockPanel>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Inspector limits" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Max audio frames in tree" Width="200" VerticalAlignment="Center" />
                        <TextBox x:Name="MaxFramesBox" Width="80" HorizontalAlignment="Left" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="Max OGG pages in tree" Width="200" VerticalAlignment="Center" />
                        <TextBox x:Name="MaxPagesBox" Width="80" HorizontalAlignment="Left" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Recent files" Padding="10">
                <DockPanel>
                    <TextBlock Text="Entries to remember" Width="160" VerticalAlignment="Center" />
                    <TextBox x:Name="RecentCountBox" Width="80" HorizontalAlignment="Left" />
                </DockPanel>
            </GroupBox>
        </StackPanel>
    </DockPanel>
</Window>
