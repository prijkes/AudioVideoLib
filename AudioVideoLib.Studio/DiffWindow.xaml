<Window x:Class="AudioVideoLib.Studio.DiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:diff="clr-namespace:AudioVideoLib.Studio.Diff"
        Title="Compare files"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="KindColumnStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Added">
                    <Setter Property="Foreground" Value="#4EC9B0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Removed">
                    <Setter Property="Foreground" Value="#F48771" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Changed">
                    <Setter Property="Foreground" Value="#DCDCAA" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Same">
                    <Setter Property="Foreground" Value="#888888" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="HeaderText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                <TextBlock x:Name="SummaryText" Margin="0,4,0,0" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
        <TabControl>
            <TabItem Header="Tags">
                <DataGrid x:Name="TagGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="22"
                          FontFamily="Consolas"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="100" />
                        <DataGridTextColumn Header="Field"   Binding="{Binding Field}"   Width="180" />
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource KindColumnStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Left"  Binding="{Binding LeftValue}"  Width="*" />
                        <DataGridTextColumn Header="Right" Binding="{Binding RightValue}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Structure">
                <DataGrid x:Name="StructureGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="22"
                          FontFamily="Consolas"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="400" />
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource KindColumnStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Left size"  Binding="{Binding LeftSize,  StringFormat=N0}" Width="110" />
                        <DataGridTextColumn Header="Right size" Binding="{Binding RightSize, StringFormat=N0}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
