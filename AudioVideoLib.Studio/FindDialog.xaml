<Window x:Class="AudioVideoLib.Studio.FindDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find in file"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8">
            Enter text or hex bytes to locate in the file.
        </TextBlock>
        <TextBox x:Name="PatternText"
                 Grid.Row="1"
                 FontFamily="Consolas"
                 Padding="4,3"
                 Margin="0,0,0,10" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <RadioButton x:Name="AsciiRadio" Content="ASCII / UTF-8" IsChecked="True" Margin="0,0,16,0" />
            <RadioButton x:Name="HexRadio"   Content="Hex bytes (e.g., FF FB 92 64)" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Find" Width="90" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True" />
            <Button Content="Cancel" Width="90" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
