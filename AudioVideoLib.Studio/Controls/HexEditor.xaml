<UserControl x:Class="AudioVideoLib.Studio.Controls.HexEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FocusVisualStyle="{x:Null}">
    <Border BorderBrush="{DynamicResource Surface3Brush}" BorderThickness="1"
            Background="#111111">
        <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- offset column: read-only -->
                <TextBox Grid.Column="0" x:Name="OffsetBox"
                         IsReadOnly="True" IsTabStop="False"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#888888"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0,0,16,0"
                         Cursor="Arrow" />

                <!-- hex column: editable, hex-filtered -->
                <TextBox Grid.Column="1" x:Name="HexBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#DDDDDD" CaretBrush="White"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0,0,16,0"
                         AcceptsReturn="False" AcceptsTab="False"
                         PreviewTextInput="HexBox_PreviewTextInput"
                         PreviewKeyDown="HexBox_PreviewKeyDown"
                         SelectionChanged="HexBox_SelectionChanged" />

                <!-- ascii column: editable, any byte -->
                <TextBox Grid.Column="2" x:Name="AsciiBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#DDDDDD" CaretBrush="White"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0"
                         AcceptsReturn="False" AcceptsTab="False"
                         PreviewTextInput="AsciiBox_PreviewTextInput"
                         PreviewKeyDown="AsciiBox_PreviewKeyDown"
                         SelectionChanged="AsciiBox_SelectionChanged" />
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
