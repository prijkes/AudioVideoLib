<UserControl x:Class="AudioVideoLib.Studio.Controls.HexEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FocusVisualStyle="{x:Null}">
    <Border BorderBrush="{DynamicResource Surface3Brush}" BorderThickness="1"
            Background="#111111"
            MouseLeftButtonDown="Surface_MouseLeftButtonDown">
        <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- offset column: read-only -->
                <TextBox Grid.Column="0" x:Name="OffsetBox"
                         IsReadOnly="True" IsTabStop="False"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#888888"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0,0,16,0"
                         Cursor="Arrow" />

                <!-- hex column: editable, hex-filtered. MinWidth keeps the caret target
                     visible and clickable when the buffer is empty. -->
                <TextBox Grid.Column="1" x:Name="HexBox"
                         MinWidth="350"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#DDDDDD" CaretBrush="White"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0,0,16,0"
                         AcceptsReturn="False" AcceptsTab="False"
                         PreviewTextInput="HexBox_PreviewTextInput"
                         PreviewKeyDown="HexBox_PreviewKeyDown"
                         SelectionChanged="HexBox_SelectionChanged">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="ApplicationCommands.Copy"      Header="Copy" />
                            <MenuItem Command="ApplicationCommands.Cut"       Header="Cut" />
                            <MenuItem Command="ApplicationCommands.Paste"     Header="Paste" />
                            <Separator />
                            <MenuItem Command="ApplicationCommands.SelectAll" Header="Select all" />
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>

                <!-- ascii column: editable, any byte. MinWidth keeps the caret target
                     visible and clickable when the buffer is empty. -->
                <TextBox Grid.Column="2" x:Name="AsciiBox"
                         MinWidth="120"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#DDDDDD" CaretBrush="White"
                         FontFamily="Consolas" FontSize="11"
                         Padding="0"
                         AcceptsReturn="False" AcceptsTab="False"
                         PreviewTextInput="AsciiBox_PreviewTextInput"
                         PreviewKeyDown="AsciiBox_PreviewKeyDown"
                         SelectionChanged="AsciiBox_SelectionChanged">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="ApplicationCommands.Copy"      Header="Copy" />
                            <MenuItem Command="ApplicationCommands.Cut"       Header="Cut" />
                            <MenuItem Command="ApplicationCommands.Paste"     Header="Paste" />
                            <Separator />
                            <MenuItem Command="ApplicationCommands.SelectAll" Header="Select all" />
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
