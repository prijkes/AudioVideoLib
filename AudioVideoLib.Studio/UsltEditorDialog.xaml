<Window x:Class="AudioVideoLib.Studio.UsltEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unsynchronized lyrics (USLT)"
        Width="560"
        Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Language (ISO-639-2, 3 chars)" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox x:Name="LanguageBox" Padding="4,3" MaxLength="3" Width="80" HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Content descriptor" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox x:Name="DescriptorBox" Padding="4,3" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Lyrics" Foreground="#666666" FontSize="11" Margin="0,0,0,2" />
            <TextBox Grid.Row="1"
                     x:Name="LyricsBox"
                     Padding="4,3"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"     Width="80"                  Click="OkButton_Click"     IsDefault="True" />
            <Button Content="Cancel" Width="80" Margin="8,0,0,0" Click="CancelButton_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
