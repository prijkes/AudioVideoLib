{
  "metadata": [
    {
      "src": [
        {
          "files": [ "AudioVideoLib/AudioVideoLib.csproj" ],
          "src": "."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "outputFormat": "mref",
      "filter": "filterConfig.yml",
      "memberLayout": "SeparatePages",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "docs/**.md", "docs/**/toc.yml", "toc.yml", "index.md" ]
      }
    ],
    "resource": [
      {
        "files": [ "docs/images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern", "templates/custom" ],
    "globalMetadata": {
      "_appName": "AudioVideoLib",
      "_appTitle": "AudioVideoLib",
      "_appFooter": "AudioVideoLib — .NET audio metadata library",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_gitContribute": {
        "repo": "https://github.com/audiovideolib/AudioVideoLib",
        "branch": "master"
      }
    },
    "markdownEngineName": "markdig"
  }
}
